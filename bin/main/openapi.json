{
  "openapi": "3.0.3",
  "info": {
    "title": "Wishlist API",
    "version": "1.0.0",
    "description": "API для управления пользователями и вишлистами."
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local server"
    }
  ],
  "tags": [
    {
      "name": "Users",
      "description": "Операции с пользователями"
    },
    {
      "name": "Wishlists",
      "description": "Операции с вишлистами"
    }
  ],
  "paths": {
    "/users": {
      "get": {
        "tags": ["Users"],
        "summary": "Получить список пользователей",
        "responses": {
          "200": {
            "description": "Список пользователей",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Users"],
        "summary": "Создать пользователя",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Пользователь создан",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Некорректные входные данные",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "tags": ["Users"],
        "summary": "Получить пользователя по id",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserId"
          }
        ],
        "responses": {
          "200": {
            "description": "Пользователь найден",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Некорректный id",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Пользователь не найден"
          }
        }
      },
      "put": {
        "tags": ["Users"],
        "summary": "Изменить имя пользователя",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangeUsernameRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Имя пользователя обновлено",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UpdateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Некорректные входные данные",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Пользователь не найден"
          }
        }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Удалить пользователя",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserId"
          }
        ],
        "responses": {
          "200": {
            "description": "Пользователь удалён",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Некорректный id",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Пользователь не найден"
          }
        }
      }
    },
    "/users/password/{id}": {
      "put": {
        "tags": ["Users"],
        "summary": "Изменить пароль пользователя",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Пароль пользователя обновлён",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UpdateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Некорректные входные данные",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Пользователь не найден"
          }
        }
      }
    },
    "/wishlists": {
      "get": {
        "tags": ["Wishlists"],
        "summary": "Получить список вишлистов",
        "responses": {
          "200": {
            "description": "Список вишлистов",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Wishlist"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Wishlists"],
        "summary": "Создать вишлист",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateWishlistRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Вишлист создан",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Wishlist"
                }
              }
            }
          },
          "400": {
            "description": "Некорректные входные данные",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "UserId": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "Положительный идентификатор пользователя",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "example": 1
        }
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "required": ["id", "username", "password"],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "username": {
            "type": "string",
            "example": "alex"
          },
          "password": {
            "type": "string",
            "example": "strongPass123"
          }
        }
      },
      "Wishlist": {
        "type": "object",
        "required": ["id", "userId", "title", "description", "visibility"],
        "properties": {
          "id": {
            "type": "integer",
            "example": 10
          },
          "userId": {
            "type": "integer",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "Подарки на день рождения"
          },
          "description": {
            "type": "string",
            "example": "Список желаемых подарков"
          },
          "visibility": {
            "$ref": "#/components/schemas/WishlistVisibility"
          }
        }
      },
      "CreateUserRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": {
            "type": "string",
            "example": "alex"
          },
          "password": {
            "type": "string",
            "example": "strongPass123"
          }
        }
      },
      "ChangeUsernameRequest": {
        "type": "object",
        "required": ["username"],
        "properties": {
          "username": {
            "type": "string",
            "example": "alex_updated"
          }
        }
      },
      "ChangePasswordRequest": {
        "type": "object",
        "required": ["password"],
        "properties": {
          "password": {
            "type": "string",
            "example": "newStrongPass123"
          }
        }
      },
      "CreateWishlistRequest": {
        "type": "object",
        "required": ["userId", "title", "description", "visibility"],
        "properties": {
          "userId": {
            "type": "integer",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "Хочу купить"
          },
          "description": {
            "type": "string",
            "example": "Список покупок"
          },
          "visibility": {
            "$ref": "#/components/schemas/WishlistVisibility"
          }
        }
      },
      "WishlistVisibility": {
        "type": "string",
        "enum": ["public", "link_only", "private"],
        "example": "public"
      },
      "UpdateResponse": {
        "type": "object",
        "required": ["updated"],
        "properties": {
          "updated": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "DeleteResponse": {
        "type": "object",
        "required": ["deleted"],
        "properties": {
          "deleted": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "string",
            "example": "Некорректный id. Используй положительное целое число."
          }
        }
      }
    }
  }
}
