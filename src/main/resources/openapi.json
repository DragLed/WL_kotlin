{
  "openapi": "3.0.3",
  "info": {
    "title": "Wishlist App API",
    "version": "1.0.0",
    "description": "REST API для приложения Wishlist App"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local server"
    }
  ],
  "tags": [
    { "name": "Auth" },
    { "name": "Users" },
    { "name": "Wishlists" },
    { "name": "Gifts" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "example": "Некорректный id"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "username": {
            "type": "string",
            "example": "DragLed"
          }
        }
      },
      "CreateUserRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": {
            "type": "string",
            "example": "DragLed"
          },
          "password": {
            "type": "string",
            "example": "qwerty123"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": {
            "type": "string",
            "example": "DragLed"
          },
          "password": {
            "type": "string",
            "example": "qwerty123"
          }
        }
      },
      "ChangeUsernameRequest": {
        "type": "object",
        "required": ["username"],
        "properties": {
          "username": {
            "type": "string",
            "example": "NewUsername"
          }
        }
      },
      "ChangePasswordRequest": {
        "type": "object",
        "required": ["password"],
        "properties": {
          "password": {
            "type": "string",
            "example": "newPassword123"
          }
        }
      },
      "TokenResponse": {
        "type": "string",
        "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
      },
      "CurrentUserResponse": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer",
            "example": 1
          }
        }
      },
      "CreateWishlistRequest": {
        "type": "object",
        "required": [
          "title",
          "description",
          "visibility"
        ],
        "properties": {
          "title": {
            "type": "string",
            "example": "Birthday Wishlist"
          },
          "description": {
            "type": "string",
            "example": "Подарки на день рождения"
          },
          "visibility": {
            "$ref": "#/components/schemas/WishlistVisibility"
          }
        }
      },

      "Wishlist": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "userId": {
            "type": "integer",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "Birthday Wishlist"
          },
          "description": {
            "type": "string",
            "example": "Подарки на день рождения"
          },
          "visibility": {
            "$ref": "#/components/schemas/WishlistVisibility"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-05-10T14:30:00"
          }
        }
      },

      "WishlistVisibility": {
        "type": "string",
        "description": "Видимость вишлиста",
        "enum": [
          "public",
          "link_only",
          "private"
        ],
        "default": "private"
      },
      "Gift": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "WishListId": {
            "type": "integer",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "PlayStation 5"
          },
          "description": {
            "type": "string",
            "example": "Sony PlayStation 5 Slim"
          },
          "price": {
            "type": "number",
            "format": "float",
            "example": 54999.99
          },
          "is_reserved": {
            "type": "boolean",
            "example": false
          },
          "reserved_by": {
            "type": "integer",
            "example": 0
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-05-10T14:30:00"
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/user": {
      "post": {
        "tags": ["Users"],
        "summary": "Регистрация пользователя",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Пользователь создан"
          },
          "400": {
            "description": "Ошибка валидации"
          }
        }
      }
    },
    "/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Авторизация",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token"
          },
          "400": {
            "description": "Неверный логин или пароль"
          }
        }
      }
    },
    "/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Выход из системы",
        "responses": {
          "200": {
            "description": "Successfully logged out"
          }
        }
      }
    },
    "/refresh": {
      "post": {
        "tags": ["Auth"],
        "summary": "Обновление access token",
        "security": [],
        "responses": {
          "200": {
            "description": "Новый access token"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Получить текущего пользователя",
        "responses": {
          "200": {
            "description": "Current user"
          }
        }
      }
    },
    "/users": {
      "get": {
        "tags": ["Users"],
        "summary": "Получить всех пользователей",
        "responses": {
          "200": {
            "description": "Список пользователей"
          }
        }
      }
    },
    "/user/{id}": {
      "get": {
        "tags": ["Users"],
        "summary": "Получить пользователя по ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Пользователь найден"
          },
          "404": {
            "description": "Пользователь не найден"
          }
        }
      },
      "put": {
        "tags": ["Users"],
        "summary": "Изменить username",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangeUsernameRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Username updated"
          }
        }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Удалить пользователя",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Пользователь удалён"
          }
        }
      }
    },
    "/user/password/{id}": {
      "put": {
        "tags": ["Users"],
        "summary": "Изменить пароль",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password updated"
          }
        }
      }
    },
    "/wishlists": {
      "get": {
        "tags": ["Wishlists"],
        "summary": "Получить список всех вишлистов",
        "responses": {
          "200": {
            "description": "Список вишлистов"
          }
        }
      }
    },
    "/wishlist": {
      "post": {
        "tags": ["Wishlists"],
        "summary": "Создать новый вишлист",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateWishlistRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Вишлист успешно создан"
          },
          "400": {
            "description": "Ошибка валидации"
          },
          "401": {
            "description": "Пользователь не авторизован"
          }
        }
      }
    },
    "/wishlist/{id}": {
      "get": {
        "tags": ["Wishlists"],
        "summary": "Получить вишлист по ID",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Вишлист найден"
          },
          "401": {
            "description": "Пользователь не авторизован"
          },
          "404": {
            "description": "Вишлист не найден или доступ запрещён"
          }
        }
      },
      "delete": {
        "tags": ["Wishlists"],
        "summary": "Удалить вишлист",
        "description": "Удалить вишлист может только его владелец.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Вишлист успешно удалён"
          },
          "401": {
            "description": "Пользователь не авторизован"
          },
          "403": {
            "description": "Нет прав на удаление"
          },
          "404": {
            "description": "Вишлист не найден"
          }
        }
      }
    },
    "/gift": {
      "post": {
        "tags": ["Gifts"],
        "summary": "Создать подарок",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Gift"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Подарок создан"
          }
        }
      }
    },
    "/gift/{id}/reserve": {
      "post": {
        "tags": ["Gifts"],
        "summary": "Забронировать подарок",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Зарезервировано"
          }
        }
      }
    },
    "/gift/{id}/unreserve": {
      "post": {
        "tags": ["Gifts"],
        "summary": "Забронировать подарок",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "201": {
            "description": "разрезервировано"
          }
        }
      }
    },
    "/gift/{id}": {
      "get": {
        "tags": ["Gifts"],
        "summary": "Получить подарок по ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Подарок найден"
          },
          "404": {
            "description": "Подарок не найден"
          }
        }
      },
      "delete": {
        "tags": ["Gifts"],
        "summary": "Удалить подарок",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Подарок удалён"
          }
        }
      }
    }
  }
}